{
	"name": "pybracket-frontend",
	"version": "0.1.0",
	"private": true,
	"description": "A browser studio for the pybracket tournament library — runs the real Python library in-browser via Pyodide.",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"check": "tsc --noEmit",
		"lint": "next lint",
		"sync-pybracket": "node scripts/sync-pybracket.mjs",
		"pages:build": "npx @cloudflare/next-on-pages",
		"preview": "npm run pages:build && npx wrangler pages dev",
		"deploy": "npm run pages:build && npx wrangler pages deploy"
	},
	"dependencies": {
		"next": "^15.3.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@cloudflare/next-on-pages": "^1.13.16",
		"@tailwindcss/postcss": "^4.1.8",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"tailwindcss": "^4.1.8",
		"typescript": "^5.8.3",
		"wrangler": "^4.19.0"
	}
}
